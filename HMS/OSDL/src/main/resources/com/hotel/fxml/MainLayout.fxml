<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hotel.controller.MainController">

    <!-- ===== SIDEBAR ===== -->
    <left>
        <VBox styleClass="sidebar" spacing="4">

            <!-- Logo / Brand -->
            <VBox styleClass="sidebar-logo-box" spacing="3">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="🏨" style="-fx-font-size:26px;"/>
                    <VBox spacing="1">
                        <Label text="Grand Azure" styleClass="sidebar-logo-title"/>
                        <Label text="Hotel Management" styleClass="sidebar-logo-sub"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox spacing="2">
                <padding><Insets top="12" right="16" bottom="8" left="16"/></padding>
                <Label text="MAIN MENU" styleClass="sidebar-section-label"/>

                <Button fx:id="btnNavRooms" text="🛏️  Rooms" styleClass="nav-btn"
                        onAction="#showRooms" maxWidth="Infinity"/>
                <Button fx:id="btnNavAddRoom" text="➕  Add Room" styleClass="nav-btn"
                        onAction="#showAddRoom" maxWidth="Infinity"/>
                <Button fx:id="btnNavCustomers" text="👤  Customers" styleClass="nav-btn"
                        onAction="#showCustomers" maxWidth="Infinity"/>
            </VBox>

            <VBox spacing="2">
                <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                <Label text="OPERATIONS" styleClass="sidebar-section-label"/>
                <Button fx:id="btnNavBooking" text="📅  New Booking" styleClass="nav-btn"
                        onAction="#showBooking" maxWidth="Infinity"/>
                <Button fx:id="btnNavCheckout" text="🚪  Checkout" styleClass="nav-btn"
                        onAction="#showCheckout" maxWidth="Infinity"/>
                <Button fx:id="btnNavBilling" text="💰  Billing" styleClass="nav-btn"
                        onAction="#showBilling" maxWidth="Infinity"/>
            </VBox>

            <!-- Spacer -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Version info -->
            <VBox spacing="4">
                <padding><Insets bottom="12"/></padding>
                <Separator/>
                <Label text="v2.0 — OSDL Project" styleClass="sidebar-version"/>
            </VBox>
        </VBox>
    </left>

    <!-- ===== CONTENT AREA ===== -->
    <center>
        <StackPane fx:id="contentArea"/>
    </center>

</BorderPane>
